<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Atheer-Rust — Mobile Inference Engine for LLMs</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  /* ─── Reset & Base ─── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #0B1120;
    color: #E2E8F0;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  a { color: #38BDF8; text-decoration: none; transition: color .2s; }
  a:hover { color: #7DD3FC; }
  img { max-width: 100%; display: block; }
  code, pre { font-family: 'JetBrains Mono', monospace; }
  ::selection { background: #38BDF8; color: #0B1120; }

  /* ─── Loading Screen ─── */
  #loading-screen {
    position: fixed; inset: 0; z-index: 9999;
    background: #0B1120;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    transition: opacity .6s ease, visibility .6s ease;
  }
  #loading-screen.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
  .loading-logo {
    font-size: 2rem; font-weight: 800; letter-spacing: -.03em;
    background: linear-gradient(135deg, #38BDF8, #06B6D4);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1.75rem;
  }
  .loading-bar-track {
    width: 220px; height: 3px; background: #1E293B; border-radius: 4px;
    overflow: hidden;
  }
  .loading-bar-fill {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, #38BDF8, #06B6D4);
    border-radius: 4px;
    transition: width .3s ease;
  }
  .loading-text {
    margin-top: .75rem; font-size: .8rem; color: #64748B;
    font-family: 'JetBrains Mono', monospace;
  }

  /* ─── Navigation ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 1rem 2rem;
    background: rgba(11,17,32,.85);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(56,189,248,.08);
    display: flex; align-items: center; justify-content: space-between;
    transition: border-color .3s;
  }
  nav.scrolled { border-color: rgba(56,189,248,.18); }
  .nav-brand {
    font-weight: 700; font-size: 1.1rem;
    background: linear-gradient(135deg, #38BDF8, #06B6D4);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    cursor: pointer;
  }
  .nav-links { display: flex; gap: 1.75rem; align-items: center; }
  .nav-links a {
    font-size: .875rem; font-weight: 500; color: #94A3B8;
    cursor: pointer;
  }
  .nav-links a:hover { color: #E2E8F0; }
  .nav-links a.nav-active { color: #38BDF8; }
  .nav-cta {
    padding: .45rem 1.1rem; border-radius: 6px;
    background: #38BDF8; color: #0B1120 !important;
    font-weight: 600; font-size: .8rem; cursor: pointer;
    transition: background .2s, transform .15s;
  }
  .nav-cta:hover { background: #7DD3FC; transform: translateY(-1px); }
  .nav-mobile-toggle {
    display: none; background: none; border: none; color: #E2E8F0;
    font-size: 1.5rem; cursor: pointer; padding: .25rem;
  }

  /* ─── Hero ─── */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero-bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(56,189,248,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56,189,248,.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 20%, transparent 70%);
  }
  .hero-glow {
    position: absolute; width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(56,189,248,.08), transparent 70%);
    top: -20%; left: 50%; transform: translateX(-50%);
    pointer-events: none;
  }
  .hero-content { position: relative; z-index: 1; max-width: 800px; }
  .hero-badge {
    display: inline-block;
    padding: .35rem 1rem;
    border-radius: 100px;
    border: 1px solid rgba(56,189,248,.2);
    background: rgba(56,189,248,.06);
    font-size: .75rem; font-weight: 600; color: #7DD3FC;
    letter-spacing: .04em; text-transform: uppercase;
    margin-bottom: 1.5rem;
    cursor: pointer;
    transition: background .2s;
  }
  .hero-badge:hover { background: rgba(56,189,248,.12); }
  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800; line-height: 1.1; letter-spacing: -.04em;
    margin-bottom: 1.25rem;
  }
  .hero h1 span {
    background: linear-gradient(135deg, #38BDF8 0%, #06B6D4 50%, #2DD4BF 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #94A3B8; max-width: 580px; margin: 0 auto 2rem;
    line-height: 1.7;
  }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .75rem 1.75rem; border-radius: 8px;
    font-size: .95rem; font-weight: 600; border: none;
    cursor: pointer;
    transition: background .2s, transform .15s, box-shadow .2s;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-primary {
    background: linear-gradient(135deg, #38BDF8, #06B6D4);
    color: #0B1120;
    box-shadow: 0 4px 20px rgba(56,189,248,.25);
  }
  .btn-primary:hover { box-shadow: 0 6px 28px rgba(56,189,248,.35); }
  .btn-secondary {
    background: rgba(56,189,248,.08);
    color: #E2E8F0;
    border: 1px solid rgba(56,189,248,.2);
  }
  .btn-secondary:hover { background: rgba(56,189,248,.15); border-color: rgba(56,189,248,.35); }
  .hero-scroll {
    position: absolute; bottom: 2rem;
    display: flex; flex-direction: column; align-items: center; gap: .5rem;
    color: #475569; font-size: .7rem; letter-spacing: .1em; text-transform: uppercase;
    cursor: pointer;
    transition: color .2s;
  }
  .hero-scroll:hover { color: #94A3B8; }
  .scroll-arrow {
    width: 20px; height: 20px;
    border-right: 2px solid #475569; border-bottom: 2px solid #475569;
    transform: rotate(45deg);
    animation: scrollBounce 2s infinite;
  }
  @keyframes scrollBounce { 0%,100%{transform:rotate(45deg) translateY(0)} 50%{transform:rotate(45deg) translateY(6px)} }

  /* ─── Section Common ─── */
  section { padding: 5rem 2rem; }
  .section-inner {
    max-width: 1100px; margin: 0 auto;
  }
  .section-label {
    font-size: .7rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: .12em; color: #38BDF8; margin-bottom: .75rem;
  }
  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700; letter-spacing: -.03em; line-height: 1.2;
    margin-bottom: 1rem;
  }
  .section-desc {
    color: #94A3B8; max-width: 600px; font-size: 1.05rem;
    line-height: 1.7;
  }
  .section-desc-wide { max-width: 700px; }

  /* ─── Stats Bar ─── */
  .stats-bar {
    padding: 2rem 2rem;
    background: #0F172A;
    border-top: 1px solid rgba(56,189,248,.06);
    border-bottom: 1px solid rgba(56,189,248,.06);
  }
  .stats-grid {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem;
  }
  .stat-item { text-align: center; }
  .stat-number {
    font-size: 2.25rem; font-weight: 800; letter-spacing: -.03em;
    background: linear-gradient(135deg, #38BDF8, #06B6D4);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
  }
  .stat-label { font-size: .8rem; color: #64748B; margin-top: .2rem; }

  /* ─── Features ─── */
  .features-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem; margin-top: 2.5rem;
  }
  .feature-card {
    background: #0F172A;
    border: 1px solid rgba(56,189,248,.08);
    border-radius: 12px; padding: 1.75rem;
    transition: border-color .25s, transform .2s, box-shadow .2s;
    cursor: default;
  }
  .feature-card:hover {
    border-color: rgba(56,189,248,.2);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,.3);
  }
  .feature-icon {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }
  .feature-icon-blue { background: rgba(56,189,248,.12); color: #38BDF8; }
  .feature-icon-cyan { background: rgba(6,182,212,.12); color: #06B6D4; }
  .feature-icon-amber { background: rgba(245,158,11,.12); color: #F59E0B; }
  .feature-icon-green { background: rgba(34,197,94,.12); color: #22C55E; }
  .feature-icon-purple { background: rgba(168,85,247,.12); color: #A855F7; }
  .feature-icon-pink { background: rgba(236,72,153,.12); color: #EC4899; }
  .feature-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: .5rem; }
  .feature-card p { font-size: .875rem; color: #94A3B8; line-height: 1.65; }

  /* ─── Architecture ─── */
  .arch-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem; margin-top: 2.5rem;
  }
  .arch-card {
    background: rgba(15,23,42,.6);
    border: 1px solid rgba(56,189,248,.08);
    border-radius: 10px; padding: 1.25rem 1.5rem;
    text-align: center;
    position: relative;
    cursor: default;
    transition: border-color .25s, transform .2s;
  }
  .arch-card:hover { border-color: rgba(56,189,248,.2); transform: translateY(-1px); }
  .arch-card.l1 { border-color: rgba(56,189,248,.15); }
  .arch-card.l2 { border-color: rgba(6,182,212,.12); }
  .arch-card.l3 { border-color: rgba(245,158,11,.1); }
  .arch-card h4 { font-size: .8rem; font-weight: 600; margin-bottom: .2rem; }
  .arch-card p { font-size: .7rem; color: #64748B; }
  .arch-arrow {
    display: none;
    position: absolute; bottom: -1.2rem; left: 50%; transform: translateX(-50%);
    color: #334155; font-size: .8rem;
  }
  .arch-row {
    display: flex; flex-wrap: wrap; gap: .75rem; justify-content: center;
    margin-top: 2rem;
  }
  .arch-pill {
    padding: .35rem 1rem; border-radius: 100px;
    font-size: .75rem; font-weight: 500;
    background: rgba(56,189,248,.06);
    border: 1px solid rgba(56,189,248,.1);
    cursor: pointer;
    transition: background .2s, border-color .2s;
  }
  .arch-pill:hover { background: rgba(56,189,248,.12); border-color: rgba(56,189,248,.25); }

  /* ─── Backend Support ─── */
  .backend-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem; margin-top: 2.5rem;
  }
  .backend-card {
    background: #0F172A;
    border: 1px solid rgba(56,189,248,.08);
    border-radius: 10px; padding: 1.5rem;
    cursor: default;
    transition: border-color .25s, transform .2s;
  }
  .backend-card:hover { border-color: rgba(56,189,248,.18); transform: translateY(-2px); }
  .backend-card h4 { font-size: .95rem; font-weight: 600; margin-bottom: .25rem; }
  .backend-card .backend-platform {
    font-size: .7rem; text-transform: uppercase; letter-spacing: .08em;
    color: #38BDF8; font-weight: 600; margin-bottom: .5rem;
  }
  .backend-card p { font-size: .8rem; color: #94A3B8; line-height: 1.6; }
  .backend-card .backend-priority {
    display: inline-block; margin-top: .75rem;
    font-size: .65rem; font-weight: 600; color: #475569;
    background: rgba(71,85,105,.2); padding: .15rem .6rem; border-radius: 4px;
  }

  /* ─── Quick Start ─── */
  .code-block-wrap {
    background: #0F172A;
    border: 1px solid rgba(56,189,248,.08);
    border-radius: 10px; overflow: hidden;
    margin-top: 2rem;
  }
  .code-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: .6rem 1.25rem;
    background: rgba(56,189,248,.04);
    border-bottom: 1px solid rgba(56,189,248,.06);
  }
  .code-header span { font-size: .75rem; color: #64748B; font-weight: 500; }
  .code-copy-btn {
    background: none; border: 1px solid rgba(56,189,248,.15);
    color: #94A3B8; font-size: .7rem; padding: .25rem .75rem;
    border-radius: 4px; cursor: pointer;
    transition: background .2s, color .2s;
    font-family: inherit;
  }
  .code-copy-btn:hover { background: rgba(56,189,248,.1); color: #E2E8F0; }
  .code-copy-btn.copied { background: rgba(34,197,94,.15); color: #22C55E; border-color: rgba(34,197,94,.3); }
  .code-block {
    padding: 1.25rem; overflow-x: auto;
    font-size: .8rem; line-height: 1.7;
    color: #CBD5E1;
  }
  .code-block .comment { color: #475569; }
  .code-block .keyword { color: #38BDF8; }
  .code-block .string { color: #A5D4FF; }
  .code-block .type { color: #2DD4BF; }
  .code-block .fn { color: #F59E0B; }
  .code-block .number { color: #F472B6; }

  /* ─── Benchmarks ─── */
  .bench-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem; margin-top: 2.5rem;
  }
  .bench-card {
    background: #0F172A;
    border: 1px solid rgba(56,189,248,.08);
    border-radius: 10px; padding: 1.5rem;
    cursor: default;
  }
  .bench-card h4 { font-size: .9rem; font-weight: 600; margin-bottom: .25rem; }
  .bench-card .bench-cat { font-size: .7rem; color: #64748B; margin-bottom: 1rem; }
  .bench-row { margin-bottom: 1rem; }
  .bench-row:last-child { margin-bottom: 0; }
  .bench-label {
    display: flex; justify-content: space-between;
    font-size: .8rem; margin-bottom: .35rem;
  }
  .bench-label span:last-child { color: #38BDF8; font-weight: 600; font-family: 'JetBrains Mono', monospace; }
  .bench-track {
    height: 5px; background: #1E293B; border-radius: 4px; overflow: hidden;
  }
  .bench-fill {
    height: 100%; width: 0%;
    border-radius: 4px;
    transition: width 1.2s cubic-bezier(.25,.46,.45,.94);
  }
  .bench-fill.blue { background: linear-gradient(90deg, #38BDF8, #60A5FA); }
  .bench-fill.cyan { background: linear-gradient(90deg, #06B6D4, #22D3EE); }
  .bench-fill.amber { background: linear-gradient(90deg, #F59E0B, #FBBF24); }
  .bench-fill.green { background: linear-gradient(90deg, #22C55E, #4ADE80); }

  /* ─── Roadmap ─── */
  .roadmap-wrap { background: #0A0F1C; }
  .roadmap-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem; margin-top: 2.5rem;
  }
  .phase-card {
    background: #0F172A;
    border: 1px solid rgba(56,189,248,.08);
    border-radius: 12px; padding: 1.5rem;
    transition: border-color .25s, transform .2s, box-shadow .2s;
    cursor: default;
    display: flex; flex-direction: column;
  }
  .phase-card:hover {
    border-color: rgba(56,189,248,.2);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,.3);
  }
  .phase-header {
    display: flex; align-items: center; gap: .75rem;
    margin-bottom: 1rem;
  }
  .phase-icon {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; flex-shrink: 0;
  }
  .phase-icon-lock { background: rgba(56,189,248,.12); color: #38BDF8; }
  .phase-icon-shield { background: rgba(6,182,212,.12); color: #06B6D4; }
  .phase-icon-bolt { background: rgba(245,158,11,.12); color: #F59E0B; }
  .phase-icon-globe { background: rgba(168,85,247,.12); color: #A855F7; }
  .phase-title-group { flex: 1; }
  .phase-title {
    font-size: .9rem; font-weight: 600; line-height: 1.3;
  }
  .phase-timeline {
    display: inline-block;
    font-size: .65rem; font-weight: 600; color: #64748B;
    background: rgba(71,85,105,.2);
    padding: .15rem .55rem; border-radius: 4px;
    margin-top: .2rem;
    letter-spacing: .02em;
  }
  .phase-list {
    list-style: none; padding: 0; margin: 0;
    flex: 1;
  }
  .phase-item {
    display: flex; align-items: flex-start; gap: .5rem;
    font-size: .78rem; line-height: 1.5;
    padding: .35rem 0;
    border-bottom: 1px solid rgba(56,189,248,.04);
    color: #94A3B8;
  }
  .phase-item:last-child { border-bottom: none; }
  .phase-item .status-icon { flex-shrink: 0; font-size: .7rem; line-height: 1.6; }
  .phase-item.done { color: #22C55E; }
  .phase-item.in-progress { color: #F59E0B; }
  .phase-item.planned { color: #94A3B8; }
  .roadmap-cta-row {
    display: flex; flex-direction: column; align-items: center;
    gap: 1rem; margin-top: 2.5rem; text-align: center;
  }
  .roadmap-note {
    font-size: .85rem; color: #64748B;
    font-family: 'JetBrains Mono', monospace;
  }
  .roadmap-note strong { color: #38BDF8; font-weight: 600; }

  /* ─── Footer ─── */
  footer {
    border-top: 1px solid rgba(56,189,248,.06);
    padding: 3rem 2rem 2rem;
  }
  .footer-inner {
    max-width: 1100px; margin: 0 auto;
    display: flex; flex-wrap: wrap; justify-content: space-between; gap: 2rem;
  }
  .footer-brand {
    font-weight: 700; font-size: 1rem;
    background: linear-gradient(135deg, #38BDF8, #06B6D4);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: .5rem;
  }
  .footer-desc { font-size: .8rem; color: #64748B; max-width: 300px; line-height: 1.6; }
  .footer-links { display: flex; gap: 2rem; }
  .footer-col h5 { font-size: .75rem; font-weight: 600; color: #94A3B8; margin-bottom: .75rem; text-transform: uppercase; letter-spacing: .08em; }
  .footer-col a {
    display: block; font-size: .8rem; color: #64748B;
    margin-bottom: .5rem; cursor: pointer;
    transition: color .2s;
  }
  .footer-col a:hover { color: #E2E8F0; }
  .footer-bottom {
    max-width: 1100px; margin: 2rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(56,189,248,.06);
    display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;
  }
  .footer-bottom p { font-size: .75rem; color: #475569; }
  .footer-bottom-links { display: flex; gap: 1rem; }
  .footer-bottom-links a { font-size: .75rem; color: #475569; cursor: pointer; }
  .footer-bottom-links a:hover { color: #94A3B8; }

  /* ─── Scroll Reveal ─── */
  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity .6s ease, transform .6s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-mobile-toggle { display: block; }
    .nav-links.open {
      display: flex; flex-direction: column;
      position: absolute; top: 100%; left: 0; right: 0;
      background: rgba(11,17,32,.96);
      backdrop-filter: blur(12px);
      padding: 1rem 2rem; gap: 1rem;
      border-bottom: 1px solid rgba(56,189,248,.1);
    }
    .stats-grid { grid-template-columns: repeat(2,1fr); gap: 1.5rem; }
    .features-grid { grid-template-columns: 1fr; }
    .roadmap-grid { grid-template-columns: repeat(2,1fr); }
    .footer-inner { flex-direction: column; }
    .footer-bottom { flex-direction: column; text-align: center; }
  }
  @media (max-width: 480px) {
    section { padding: 3rem 1.25rem; }
    .hero { padding: 5rem 1.25rem 3rem; }
    .hero-actions { flex-direction: column; align-items: center; }
    .btn { width: 100%; justify-content: center; }
    .stats-grid { grid-template-columns: repeat(2,1fr); }
    .roadmap-grid { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    .hero-bg-grid { display: none; }
    .stat-number { transition: none; }
    .bench-fill { transition: none; }
  }
</style>
</head>
<body>

